{
  "name": "gsd-tools",
  "version": "1.0.0",
  "description": "CLI utility for GSD workflow operations",
  "bin": {
    "gsd-tools": "./bin/gsd-tools.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test bin/gsd-tools.test.cjs",
    "build": "node build.js",
    "audit:dead-code": "npx knip --include exports,files --workspace .",
    "audit:circular": "npx madge --circular src/"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "knip": "^5.85.0",
    "madge": "^8.0.0"
  },
  "private": true,
  "dependencies": {
    "acorn": "^8.16.0",
    "tokenx": "^1.3.0"
  }
}
